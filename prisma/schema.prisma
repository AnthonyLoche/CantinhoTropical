generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
}

model Brand {
  id        String    @id @default(cuid())
  name      String    @unique
  imageUrl  String

  products  Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  imageUrl    String

  products    Product[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id              String    @id @default(cuid())

  name            String
  description     String?

  price           Decimal   @db.Decimal(10,2)

  stockQuantity   Int       @default(0)

  imageUrl        String

  active          Boolean   @default(true)

  featured        Boolean   @default(false)

  hint             String? @default("")
  how_use          String? @default("")
  ingredients       String? @default("")

  brandId         String
  categoryId      String

  brand           Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  category        Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  variants       ProductVariants[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model ProductVariants {
  id         String    @id @default(cuid())
  label        String
  quantity     Int       @default(0)
  price        Decimal   @db.Decimal(10,2)

  productId    String
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model TextContent {
  id        String   @id @default(cuid())
  
  // Hero Section
  heroBadge        String?  @db.Text
  heroTitle        String?  @db.Text
  heroDescription  String?  @db.Text
  
  // Categories Section
  categoriesTitle       String?  @db.Text
  categoriesDescription String?  @db.Text
  
  // About Section
  aboutTitle       String?  @db.Text
  aboutDescription String?  @db.Text
  
  // Pet Hotel Section
  petHotelChip     String?  @db.Text
  petHotelTitle    String?  @db.Text
  petHotelDescription String? @db.Text
  
  // Contact Section
  contactTitle     String?  @db.Text
  contactDescription String? @db.Text
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("home_contents")
}